# Githome server configuration, read by the systemd unit from
# /etc/githome/githome.env. Edit the values below, then enable the service:
#
#   sudo systemctl enable --now githome
#
# This file is marked as a config file, so a package upgrade will not overwrite
# your edits.

# --- Required ---

# Where the metadata lives. The default uses the bundled pure-Go SQLite driver.
GITHOME_DATABASE_URL=sqlite:///var/lib/githome/githome.sqlite

# Working directory for repositories and other on-disk state.
GITHOME_DATA_DIR=/var/lib/githome

# The absolute public base URL clients use to reach this server. It must not be
# a github.com host. Set this to the real scheme/host/port you serve on.
GITHOME_HTML_BASE_URL=http://localhost:3000

# Secrets. Generate each with: openssl rand -hex 32
# The server refuses to start until these are set (session key >= 32 bytes,
# token pepper >= 16 chars).
GITHOME_SESSION_KEY=
GITHOME_TOKEN_PEPPER=

# --- Optional ---

# Address the HTTP server listens on. Defaults to :3000.
GITHOME_LISTEN_HTTP=:3000

# Log verbosity: debug, info, warn, error.
GITHOME_LOG_LEVEL=info

# Runtime environment: development or production. Production logs as JSON.
GITHOME_ENV=production
